// Prisma schema for TrackMyApply AI.
// See docs/milestone-plan.md for what each model/field belongs to.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?

  // Milestone 7 (batch 4): opt-in preference for the email reminder MVP —
  // conservative default (off) so no email is ever sent until a user
  // explicitly enables it in Settings.
  emailRemindersEnabled Boolean @default(false)
  // Milestone 7 (batch 6): cadence for reminder emails, scoped to this
  // feature only. IMMEDIATE preserves the original one-per-task-per-day
  // behavior; DAILY_DIGEST bundles all of a user's eligible reminders into
  // one email per day. lastDigestEmailSentAt is the digest-mode dedup
  // marker (immediate mode already dedupes per-task via
  // Task.lastReminderEmailSentAt).
  reminderEmailFrequency ReminderEmailFrequency @default(IMMEDIATE)
  lastDigestEmailSentAt  DateTime?

  accounts            Account[]
  sessions            Session[]
  profile             Profile?
  applications        Application[]
  resumes             Resume[]
  interviewPreps      InterviewPrep[]
  tasks               Task[]
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Reserved for future OAuth providers; unused while the Credentials
// provider is the only sign-in method.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Unused while sessions use the JWT strategy (required for the Credentials
// provider); kept for parity with the standard Auth.js Prisma schema.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password reset ("forgot password") flow. Only the SHA-256 hash of the
// reset token is stored here — the raw token lives only in the emailed
// link, so a database leak can't be used to reset anyone's password. Rows
// are single-use (deleted once consumed) and short-lived (`expires`, ~1h);
// stale rows are also cleared whenever a new reset is requested for the
// same user, so at most one live token exists per account at a time.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expires   DateTime

  createdAt DateTime @default(now())

  @@index([userId])
}

enum ApplicationStatus {
  SAVED
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

// Milestone 7 (batch 6): reminder email cadence — deliberately just two
// modes, scoped to reminder emails only (not a general notification
// preference).
enum ReminderEmailFrequency {
  IMMEDIATE
  DAILY_DIGEST
}

// Milestone 1: per-user job application tracker.
model Application {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  company String
  role    String
  jobUrl  String?
  source  String?

  status ApplicationStatus @default(SAVED)

  dateApplied DateTime?
  // TRANSITIONAL (Milestone 1): free-text resume label, e.g. "Data-focused
  // v2". Superseded by the `resume` relation below. Still read/written by
  // the M1 UI (application-form.tsx, applications-table.tsx, actions.ts) —
  // remove only once that UI is migrated to `resumeId` in a later batch.
  resumeVersion String?
  resumeId      String?
  resume        Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  followUpDate  DateTime?
  notes         String?   @db.Text
  // Milestone 3: source material for future resume tailoring/fit scoring.
  jobDescription String? @db.Text
  // GetHired AI: generated cover letter for this application.
  coverLetter String? @db.Text

  // Milestone 4 (batch 1): 1:1 interview prep record. Schema-only for
  // now — no UI reads/writes this relation yet.
  interviewPrep InterviewPrep?

  // Milestone 5 (batch 1): follow-up tasks/reminders, many per application.
  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([userId, followUpDate])
  @@index([userId, resumeId])
}

// Milestone 2 (batch 1): resume versions. UI/actions land in a later batch —
// this model is schema-only for now.
model Resume {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title        String
  versionLabel String?
  baseRole     String?
  fileUrl      String?
  content      String? @db.Text
  notes        String? @db.Text

  // GetHired AI tailoring pipeline: structured resume JSON (contact +
  // sections) used to render the print/PDF view and the .tex export, plus
  // the ATS keyword-coverage score of this resume against the JD it was
  // tailored for, the base resume's score against the same JD (for the
  // before/after comparison), and the detailed matched/missing report.
  structured Json?
  matchScore Int?
  baseScore  Int?
  atsReport  Json?

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, title])
}

// Milestone 4 (batch 1): interview prep storage, one record per
// application. likelyQuestions/starStories are Json so their shape can
// evolve (e.g. once AI generation lands) without another migration.
model InterviewPrep {
  id            String @id @default(cuid())
  applicationId String @unique
  userId        String

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  prepNotes       String? @db.Text
  likelyQuestions Json?
  starStories     Json?
  companyResearch String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

enum TaskStatus {
  TODO
  DOING
  DONE
  DISMISSED
}

// Milestone 5 (batch 1): simple follow-up tasks/reminders attached to an
// application, e.g. "send thank-you email", "research team", "check back
// in a week". Deliberately minimal — no notifications/scheduling yet.
model Task {
  id            String @id @default(cuid())
  applicationId String
  userId        String

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  dueDate     DateTime?
  status      TaskStatus @default(TODO)
  completedAt DateTime?
  // Milestone 7 (batch 1): optional reminder, distinct from dueDate — e.g.
  // "due Friday" (the interview) with a reminder set for Wednesday (prep
  // beforehand). Date-only in the UI for now, same as dueDate; in-app
  // visibility only, no external delivery yet.
  reminderAt DateTime?
  // Milestone 7 (batch 3): set when the user dismisses a reminder from the
  // dashboard's active reminder surface. Deliberately separate from
  // reminderAt — dismissing hides the reminder from that surface without
  // losing the original date or touching dueDate/status/the task itself.
  // Cleared whenever reminderAt is set again (editing a task's reminder is
  // a fresh start), so a stale dismiss can't silently suppress a new one.
  reminderDismissedAt DateTime?
  // Milestone 7 (batch 4): when a reminder email was last sent for this
  // task — the dedup guard for the email MVP (at most one email per task
  // per UTC calendar day). Only set after a send actually succeeds, so a
  // failed/skipped send (e.g. provider not configured) never falsely marks
  // a reminder as already emailed.
  lastReminderEmailSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId, status])
  @@index([applicationId, dueDate])
  @@index([userId, status])
  @@index([userId, reminderAt])
}

// GetHired AI: full candidate profile, captured right after first sign-in.
// This is the source of truth the AI mentor uses for resume generation,
// JD tailoring, cover letters, and job matching. All fields optional so
// onboarding can be completed incrementally; onboardedAt marks completion.
model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName       String?
  headline       String?
  phone          String?
  location       String?
  linkedinUrl    String?
  githubUrl      String?
  portfolioUrl   String?
  summary        String? @db.Text
  skills         String? @db.Text
  experience     String? @db.Text
  education      String? @db.Text
  projects       String? @db.Text
  certifications String? @db.Text

  // Job-finder preferences.
  targetRoles     String?
  targetLocations String?
  workPreference  String?
  experienceLevel String?

  onboardedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
