# Copy this file to .env and fill in real values. .env is gitignored.
# Never commit real secrets into this file — placeholders only.

# PostgreSQL connection string used by Prisma (schema + migrations).
# For Vercel/serverless deployments, use Neon's POOLED connection string
# (the "-pooler" endpoint from the Neon dashboard), not the direct one —
# each serverless invocation opens its own connection, and the direct
# endpoint can exhaust Postgres's connection limit under concurrent load.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Auth.js (NextAuth v5) secret used to sign/encrypt session JWTs.
# Generate one with: npx auth secret
# That command prints a line like `AUTH_SECRET=<hex>` — use only the hex
# value here, not the whole "AUTH_SECRET=..." line.
AUTH_SECRET=""

# OpenAI API key. Required for resume tailoring (Milestone 3) and future
# JD parsing / fit scoring / interview prep features.
OPENAI_API_KEY=""

# Optional: override the default tailoring model (see src/lib/ai/tailor-resume.ts).
OPENAI_MODEL=""

# Resend API key. Required for the email reminder MVP (Milestone 7 Batch 4)
# to actually send anything — without it, findEligibleReminderEmails still
# runs, but each send attempt fails gracefully (logged, not thrown) and no
# reminder is marked as sent.
RESEND_API_KEY=""

# Optional: override the reminder email "from" address (see
# src/lib/email/send-reminder-email.ts). Must be a verified sender/domain
# in Resend, or delivery will fail. Defaults to a placeholder address.
REMINDER_EMAIL_FROM=""

# Base URL used to build the "open it in the app" / unsubscribe links in
# reminder emails. Optional on Vercel — falls back to
# VERCEL_PROJECT_PRODUCTION_URL or VERCEL_URL (auto-injected by Vercel) if
# unset, then to http://localhost:3000 for local dev. Set this explicitly
# only if you're using a custom domain and want emails to always link to it
# regardless of which Vercel URL env var is present at build/runtime.
APP_BASE_URL=""

# Shared secret the reminder-email cron endpoint (/api/cron/reminder-emails)
# requires as `Authorization: Bearer <CRON_SECRET>` — the same convention
# Vercel Cron uses natively when this env var is set on the project. The
# route refuses all requests if this isn't set, since it sends real email.
CRON_SECRET=""
